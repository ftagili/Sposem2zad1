Pipe openPipeDevice(int address);
Pipe createPipe();
Stream getInputStream(Pipe pipe);
Stream getOutputStream(Pipe pipe);
int createThread(int procId, int params);
int makeSourceParams(Stream input, Stream output);
int makeRrParams(Stream input, Stream output, int quantum, int burstMin, int burstMax,
                 int meanGapT10);
int makeReportParams(Stream input, Stream output);
int waitAllThreads();

Stream getFirstInput(int params);
Stream getOutput(int params);
int getQuantum(int params);
int getBurstMin(int params);
int getBurstMax(int params);
int getMeanGapT10(int params);
bool canRead(Stream input);
int closeWriter(Stream output);

Task readTask(Stream input);
int writeTask(Stream output, Task task);
TaskQueue createTaskQueue();
bool hasTasks(TaskQueue queue);
int pushTail(TaskQueue queue, Task task);
Task popFirstTask(TaskQueue queue);
Task executeOneTick(Task task);
int getRemainingTime(Task task);

ScheduleEvent makeScheduleEvent(Task task);
int writeScheduleEvent(Stream output, ScheduleEvent event);
ScheduleEvent readScheduleEvent(Stream input);

ReportState createReportState();
ReportState applyScheduleEvent(ReportState state, ScheduleEvent event);
int writeText(Stream output, string text);
string formatRrReport(ReportState state, int quantum, int burstMin, int burstMax,
                      int meanGapT10);

int WorkloadSourceProc(int params) {
    Stream input = getFirstInput(params);
    Stream output = getOutput(params);

    while (canRead(input)) {
        writeTask(output, readTask(input));
    }

    closeWriter(output);
    return 0;
}

int RoundRobinSchedulerProc(int params) {
    Stream input = getFirstInput(params);
    Stream output = getOutput(params);
    int quantum = getQuantum(params);
    int sliceLeft = quantum;
    TaskQueue readyQueue = createTaskQueue();
    Task current;
    bool hasCurrent = false;
    int keepRunning = 1;

    while (keepRunning) {
        if (canRead(input)) {
            pushTail(readyQueue, readTask(input));
        }

        if (hasCurrent == false) {
            if (hasTasks(readyQueue)) {
                current = popFirstTask(readyQueue);
                hasCurrent = true;
                sliceLeft = quantum;
            }
        }

        if (hasCurrent) {
            current = executeOneTick(current);
            sliceLeft = sliceLeft - 1;
            writeScheduleEvent(output, makeScheduleEvent(current));

            if (getRemainingTime(current) == 0) {
                hasCurrent = false;
            } else if (sliceLeft == 0) {
                pushTail(readyQueue, current);
                hasCurrent = false;
            }
        }

        keepRunning = 0;
        if (canRead(input)) {
            keepRunning = 1;
        }
        if (hasTasks(readyQueue)) {
            keepRunning = 1;
        }
        if (hasCurrent) {
            keepRunning = 1;
        }
    }

    closeWriter(output);
    return 0;
}

int SchedulerReportProc(int params) {
    Stream input = getFirstInput(params);
    Stream output = getOutput(params);
    ReportState report = createReportState();

    while (canRead(input)) {
        report = applyScheduleEvent(report, readScheduleEvent(input));
    }

    writeText(output,
              formatRrReport(report, getQuantum(params), getBurstMin(params), getBurstMax(params),
                             getMeanGapT10(params)));
    closeWriter(output);
    return 0;
}

int main() {
    Pipe rawTasksPipe = openPipeDevice(0x020000);
    Pipe scheduledPipe = createPipe();
    Pipe reportItemsPipe = createPipe();
    Pipe resultsPipe = openPipeDevice(0x030200);

    createThread(WorkloadSourceProc,
                 makeSourceParams(getInputStream(rawTasksPipe), getOutputStream(scheduledPipe)));
    createThread(RoundRobinSchedulerProc,
                 makeRrParams(getInputStream(scheduledPipe), getOutputStream(reportItemsPipe),
                              3, 4, 10, 105));
    createThread(SchedulerReportProc,
                 makeReportParams(getInputStream(reportItemsPipe), getOutputStream(resultsPipe)));

    return waitAllThreads();
}
